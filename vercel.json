{
  "rewrites": [
    { "source": "/cadastro", "destination": "/cadastro.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/painel", "destination": "/dashboard.html" },
    { "source": "/esqueci-senha", "destination": "/esqueci-senha.html" },
    { "source": "/redefinir-senha", "destination": "/redefinir-senha.html" },
    { "source": "/verificacao", "destination": "/ajuda-verificacao.html" },
    { "source": "/indoor", "destination": "/indoor/dashboard.html" },
    { "source": "/indoor/login", "destination": "/indoor/login.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-blobs",
      "schedule": "0 4 * * *"
    }
  ]
}